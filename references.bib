@article{hendrickx_2021_Nature_FourqubitGermaniumQuantum,
  title = {A Four-Qubit Germanium Quantum Processor},
  author = {Hendrickx, Nico W. and Lawrie, William I. L. and Russ, Maximilian and {van Riggelen}, Floor and {de Snoo}, Sander L. and Schouten, Raymond N. and Sammak, Amir and Scappucci, Giordano and Veldhorst, Menno},
