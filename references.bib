}

@article{vanriggelen_APL_TwodimensionalArraySinglehole2021,
  title = {A Two-Dimensional Array of Single-Hole Quantum Dots},
  author = {{van Riggelen}, F. and Hendrickx, N. W. and Lawrie, W. I. L. and Russ, M. and Sammak, A. and Scappucci, G. and Veldhorst, M.},
