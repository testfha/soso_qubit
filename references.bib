@article{seidler_2022_npjQuant_ConveyormodeSingleelectronShuttling,
  title = {Conveyor-Mode Single-Electron Shuttling in {{Si}}/{{SiGe}} for a Scalable Quantum Computing Architecture},
  author = {Seidler, Inga and Struck, Tom and Xue, Ran and Focke, Niels and Trellenkamp, Stefan and Bluhm, Hendrik and Schreiber, Lars R.},
  date = {2022-08-30},
  year = {2022},
