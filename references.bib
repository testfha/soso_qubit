@article{mauro_2024_PRB_GeometryDephasingSweetSpot,
  title = {Geometry of the Dephasing Sweet Spots of Spin-Orbit Qubits},
  author = {Mauro, Lorenzo and {Rodr{\'i}guez-Mena}, Esteban A. and Bassi, Marion and Schmitt, Vivien and Niquet, Yann-Michel},
  year = {2024},
  month = apr,
  journal = {Physical Review B},
  volume = {109},
