@article{eeninkTunableCouplingIsolation2019,
  title = {Tunable {{Coupling}} and {{Isolation}} of {{Single Electrons}} in {{Silicon Metal-Oxide-Semiconductor Quantum Dots}}},
  author = {Eenink, H. G. J. and Petit, L. and Lawrie, W. I. L. and Clarke, J. S. and Vandersypen, L. M. K. and Veldhorst, M.},
  year = {2019},
