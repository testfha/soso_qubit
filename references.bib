@article{burkard_2023_RevModPhys_SemiconductorSpinQubits,
  title = {Semiconductor {{Spin Qubits}}},
  author = {Burkard, Guido and Ladd, Thaddeus D. and Nichol, John M. and Pan, Andrew and Petta, Jason R.},
