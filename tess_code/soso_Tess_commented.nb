Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "sigmaz", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"hz", "=", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{"dJ12", " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"g1", "+", "g2", "-", 
            RowBox[{"2", " ", "g3"}]}], ")"}], "2"]}], 
        RowBox[{"4", " ", 
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["g1", "2"], "+", 
           SuperscriptBox["g2", "2"], "-", 
           RowBox[{"2", " ", 
            RowBox[{"(", 
             RowBox[{"g1", "+", "g2"}], ")"}], " ", "g3"}], "+", 
           RowBox[{"2", " ", 
            SuperscriptBox["g3", "2"]}]}], ")"}]}]], "*", 
       RowBox[{"PauliMatrix", "[", "3", "]"}]}], "/.", "g1t"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Uz", "[", "t_", "]"}], ":=", 
    RowBox[{
     RowBox[{"MatrixExp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], "*", "hz", "*", "t"}], "]"}], "//", 
     "FullSimplify"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"soltarz", "=", 
     RowBox[{"First", "@", 
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"hz", "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "1"}], "]"}], "]"}], "*", "t"}], "==", 
         RowBox[{"Pi", "/", "2"}]}], ",", "t"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Uztarget", "=", 
    RowBox[{
     RowBox[{"Uz", "[", "t", "]"}], "/.", "soltarz"}]}], "\[IndentingNewLine]", 
   RowBox[{"tztarget", "=", 
    RowBox[{"soltarz", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.983024387206352*^9, 3.9830244566923237`*^9}, {
  3.983024509214281*^9, 3.9830245670754547`*^9}, {3.983024620473242*^9, 
