Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"Needs", "[", "\"\<MaTeX`\>\"", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SetOptions", "[", 
     RowBox[{"MaTeX", ",", 
      RowBox[{"\"\<Preamble\>\"", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<\\\\usepackage{amsmath}\>\"", 
         ",", "\"\<\\\\usepackage{lmodern}\>\""}], "}"}]}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"tex", "[", 
      RowBox[{"s_", ",", 
       RowBox[{"fs_", ":", "20"}]}], "]"}], ":=", 
     RowBox[{"MaTeX", "[", 
      RowBox[{"s", ",", 
       RowBox[{"FontSize", "->", "fs"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"niceColors", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"RGBColor", "[", 
        RowBox[{"0.20", ",", "0.30", ",", "0.60"}], "]"}], ",", 
       RowBox[{"RGBColor", "[", 
        RowBox[{"0.60", ",", "0.20", ",", "0.30"}], "]"}], ",", 
       RowBox[{"RGBColor", "[", 
        RowBox[{"0.20", ",", "0.45", ",", "0.30"}], "]"}], ",", 
       RowBox[{"RGBColor", "[", 
        RowBox[{"0.45", ",", "0.35", ",", "0.15"}], "]"}], ",", 
       RowBox[{"RGBColor", "[", 
        RowBox[{"0.35", ",", "0.35", ",", "0.35"}], "]"}], ",", 
       RowBox[{"RGBColor", "[", 
        RowBox[{"0.25", ",", "0.40", ",", "0.50"}], "]"}]}], "}"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vals", "=", 
     RowBox[{"Sort", "[", 
      RowBox[{"Eigenvalues", "[", "Hex", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cols", "=", 
     RowBox[{"Take", "[", 
      RowBox[{"niceColors", ",", 
       RowBox[{"UpTo", "[", 
        RowBox[{"Length", "[", "vals", "]"}], "]"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"jid", "=", "13.6216"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"evAtIdle", "=", 
     RowBox[{"Sort", "@", 
      RowBox[{"Eigenvalues", "[", 
       RowBox[{"Hex", "/.", " ", 
        RowBox[{"J12", "->", "jid"}]}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Eidle", "=", 
     RowBox[{"Mean", "@", 
      RowBox[{"evAtIdle", "[", 
       RowBox[{"[", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}], "]"}], "]"}]}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
    "center", " ", "between", " ", "the", " ", "two", " ", "lowest", " ", 
     "levels"}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"purple", "=", 
     RowBox[{"RGBColor", "[", 
      RowBox[{"0.45", ",", "0.20", ",", "0.70"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"p", "=", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", "vals", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"J12", ",", "0", ",", "30"}], "}"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Directive", "[", 
           RowBox[{"Thick", ",", "#"}], "]"}], "&"}], "/@", "cols"}], ")"}]}],
       ",", 
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"FrameStyle", "->", "Black"}], ",", 
      RowBox[{"FrameTicksStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", 
         RowBox[{"FontFamily", "->", "\"\<Times\>\""}], ",", "16"}], "]"}]}], 
      ",", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"TicksStyle", "->", 
         RowBox[{"Directive", "[", 
          RowBox[{"Black", ",", 
           RowBox[{"FontFamily", "->", "\"\<Times\>\""}], ",", "18"}], 
          "]"}]}], ","}], "*)"}], 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"tex", "[", 
          RowBox[{"\"\<J_{12}/h, \\ \\ \\\\text{MHz}\>\"", ",", "18"}], "]"}],
          ",", 
         RowBox[{"tex", "[", 
          RowBox[{"\"\<\\\\text{eigenenergies, MHz}\>\"", ",", "18"}], "]"}]}]
         , "}"}]}], ",", 
      RowBox[{"PlotLabel", "->", 
       RowBox[{"tex", "[", 
        RowBox[{"\"\<S_z^{\\\\text{total}}=-\\\\frac{1}{2}\\\\ \
\\\\text{subspace}\>\"", ",", "18"}], "]"}]}], ",", 
      RowBox[{"GridLines", "->", "None"}], ",", 
      RowBox[{"AspectRatio", "->", "1"}], ",", 
      RowBox[{"ImageSize", "->", "320"}], ",", 
      RowBox[{"ImagePadding", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"60", ",", "15"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"50", ",", "20"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"PlotRangeClipping", "->", "False"}], ",", 
      RowBox[{"Epilog", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Inset", "[", 
          RowBox[{
           RowBox[{"Graphics", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Directive", "[", 
               RowBox[{"purple", ",", "Thick"}], "]"}], ",", 
              RowBox[{"Circle", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"0", ",", "0"}], "}"}], ",", "1"}], "]"}]}], "}"}], 
            "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"jid", ",", "Eidle"}], "}"}], ",", "Center", ",", 
           RowBox[{"Scaled", "[", "0.08", "]"}]}], "]"}], ",", 
         RowBox[{"Inset", "[", 
          RowBox[{
           RowBox[{"tex", "[", 
            RowBox[{"\"\<\\\\text{idle point}\>\"", ",", "18"}], "]"}], ",", 
           RowBox[{"Offset", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"35", ",", "25"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"jid", ",", "Eidle"}], "}"}]}], "]"}]}], "]"}]}], 
        "}"}]}]}], "]"}]}], "\n", "\n", "\n", "\n", "\n"}]}]], "Input",
