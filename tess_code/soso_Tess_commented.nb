Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "sigmax", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"solJ12", "=", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{
           RowBox[{"dJ12", " ", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"g1", "+", "g2", "-", 
               RowBox[{"2", " ", "g3"}]}], ")"}], "2"]}], "-", 
           RowBox[{"dJ23", " ", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"g2", "-", "g3"}], ")"}], "2"]}]}], 
          RowBox[{"4", " ", 
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox["g1", "2"], "+", 
             SuperscriptBox["g2", "2"], "-", 
             RowBox[{"2", " ", 
              RowBox[{"(", 
               RowBox[{"g1", "+", "g2"}], ")"}], " ", "g3"}], "+", 
             RowBox[{"2", " ", 
              SuperscriptBox["g3", "2"]}]}], ")"}]}]], "==", "0"}], "/.", 
        "g1t"}], ",", "dJ12"}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1", ",", "2", ",", "1"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"hx", "=", 
     RowBox[{
      FractionBox[
       RowBox[{"dJ23", "*", 
        RowBox[{"PauliMatrix", "[", "1", "]"}]}], 
       RowBox[{"2", " ", 
        SqrtBox[
         RowBox[{"1", "+", 
          FractionBox[
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"g2", "-", "g3"}], ")"}], "2"], 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"g1", "-", "g3"}], ")"}], "2"]]}]]}]], "/.", "g1t"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Ux", "[", "t_", "]"}], ":=", 
    RowBox[{
     RowBox[{"MatrixExp", "[", 
      RowBox[{
       RowBox[{"-", "I"}], "*", "hx", "*", "t"}], "]"}], "//", 
     "FullSimplify"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"soltarx", "=", 
     RowBox[{"First", "@", 
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"hx", "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "2"}], "]"}], "]"}], "*", "t"}], "==", 
         RowBox[{"Pi", "/", "2"}]}], ",", "t"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Uxtarget", "=", 
    RowBox[{
     RowBox[{"Ux", "[", "t", "]"}], "/.", "soltarx"}]}], "\[IndentingNewLine]", 
   RowBox[{"txtarget", "=", 
    RowBox[{"soltarx", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "2"}], "]"}], "]"}]}], 
   "\[IndentingNewLine]"}]}]], "Input",
