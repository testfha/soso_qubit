        RowBox[{"{", 
         RowBox[{"m", "=", 
          RowBox[{"averagedMetricsQS", "[", 
           RowBox[{"Jint", ",", "nSampQS"}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"tGateNs", "[", "Jint", "]"}], ",", 
          RowBox[{"m", "[", "\"\<Infidelity\>\"", "]"}], ",", 
          RowBox[{"m", "[", "\"\<Leakage\>\"", "]"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"Jint", ",", "jintList"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
