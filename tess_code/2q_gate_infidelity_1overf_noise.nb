      RowBox[{"-", "4"}]}]}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"fast", " ", "first", " ", "pass"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
