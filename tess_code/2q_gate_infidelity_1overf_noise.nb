Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "noiseTrace1f", ",", "oneSample1fCorr", ",", "averagedMetrics1fCorr"}], 
    "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "noiseTrace1fAlpha", ",", "gateDts", ",", "oneSample1fCorr", ",", 
     "averagedMetrics1fCorr"}], "]"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"noiseTrace1fAlpha", "[", 
     RowBox[{"amp1Hz_", ",", 
      RowBox[{"tExpUs_", ":", "1."}], ",", 
      RowBox[{"dtStepUs_", ":", "0.0005"}], ",", 
      RowBox[{"fLowHz_", ":", "1."}], ",", 
      RowBox[{"alpha_", ":", "1."}], ",", 
      RowBox[{"window_", ":", "100"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "nPts", ",", "fNyqHz", ",", "edgesHz", ",", "fMHz", ",", "binPower", ",",
         "phi", ",", "a"}], "}"}], ",", 
      RowBox[{
       RowBox[{"nPts", "=", 
        RowBox[{"Ceiling", "[", 
         RowBox[{"tExpUs", "/", "dtStepUs"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"fNyqHz", "=", 
        RowBox[{
         RowBox[{"10.", "^", "6"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "dtStepUs"}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"edgesHz", "=", 
        RowBox[{"Exp", "@", 
         RowBox[{"Subdivide", "[", 
          RowBox[{
           RowBox[{"Log", "[", "fLowHz", "]"}], ",", 
           RowBox[{"Log", "[", "fNyqHz", "]"}], ",", "window"}], "]"}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"fMHz", "=", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"Most", "[", "edgesHz", "]"}], " ", 
           RowBox[{"Rest", "[", "edgesHz", "]"}]}], "]"}], "/", 
         RowBox[{"10.", "^", "6"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"binPower", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"PossibleZeroQ", "[", 
           RowBox[{"alpha", "-", "1"}], "]"}], ",", 
          RowBox[{"Log", "[", 
           RowBox[{
            RowBox[{"Rest", "[", "edgesHz", "]"}], "/", 
            RowBox[{"Most", "[", "edgesHz", "]"}]}], "]"}], ",", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"Rest", "[", "edgesHz", "]"}], "^", 
              RowBox[{"(", 
               RowBox[{"1", "-", "alpha"}], ")"}]}], "-", 
             RowBox[{
              RowBox[{"Most", "[", "edgesHz", "]"}], "^", 
              RowBox[{"(", 
               RowBox[{"1", "-", "alpha"}], ")"}]}]}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"1", "-", "alpha"}], ")"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"phi", "=", 
        RowBox[{"RandomReal", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"2", " ", "Pi"}]}], "}"}], ",", "window"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"a", "=", 
        RowBox[{"amp1Hz", " ", 
         RowBox[{"Sqrt", "[", "binPower", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"a", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{
             RowBox[{"2", " ", "Pi", " ", "fMHz", " ", 
              RowBox[{"(", 
               RowBox[{"k", " ", "dtStepUs"}], ")"}]}], "+", "phi"}], "]"}]}],
           "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "0", ",", 
           RowBox[{"nPts", "-", "1"}]}], "}"}]}], "]"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"gateDts", "[", 
     RowBox[{"tg_", ",", "dtStepUs_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"n", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"1", ",", 
          RowBox[{"Ceiling", "[", 
           RowBox[{"tg", "/", "dtStepUs"}], "]"}]}], "]"}]}], "}"}], ",", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"ConstantArray", "[", 
         RowBox[{"dtStepUs", ",", 
          RowBox[{"n", "-", "1"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"tg", "-", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"n", "-", "1"}], ")"}], " ", "dtStepUs"}]}], "}"}]}], 
       "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"oneSample1fCorr", "[", 
     RowBox[{
      RowBox[{"Jint_", "?", "NumericQ"}], ",", 
      RowBox[{"ampJ12_", ":", 
       RowBox[{"2.5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"ampJint_", ":", 
       RowBox[{"5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"corr_", ":", "0.5"}], ",", 
      RowBox[{"tExpUs_", ":", "1."}], ",", 
      RowBox[{"dtStepUs_", ":", "0.0005"}], ",", 
      RowBox[{"alpha_", ":", "1."}], ",", 
      RowBox[{"window_", ":", "100"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "tg", ",", "dts", ",", "nSeg", ",", "nCommon", ",", "nLocal12a", ",", 
        "nLocal12b", ",", "nLocalInt", ",", "n12a", ",", "n12b", ",", "nint", 
        ",", "U", ",", "K", ",", "Uid", ",", 
        RowBox[{"d", "=", "4"}], ",", "fid", ",", "leak"}], "}"}], ",", 
      RowBox[{
       RowBox[{"tg", "=", 
        RowBox[{"tGate", "[", "Jint", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"tg", ">", "tExpUs"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"<|", 
           RowBox[{
            RowBox[{"\"\<Infidelity\>\"", "->", "Indeterminate"}], ",", 
            RowBox[{"\"\<Leakage\>\"", "->", "Indeterminate"}]}], "|>"}], 
          "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"dts", "=", 
        RowBox[{"gateDts", "[", 
         RowBox[{"tg", ",", "dtStepUs"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nSeg", "=", 
        RowBox[{"Length", "[", "dts", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nCommon", "=", 
        RowBox[{"Take", "[", 
         RowBox[{
          RowBox[{"noiseTrace1fAlpha", "[", 
           RowBox[{
           "1.", ",", "tExpUs", ",", "dtStepUs", ",", "1.", ",", "alpha", ",",
             "window"}], "]"}], ",", "nSeg"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nLocal12a", "=", 
        RowBox[{"Take", "[", 
         RowBox[{
          RowBox[{"noiseTrace1fAlpha", "[", 
           RowBox[{
           "1.", ",", "tExpUs", ",", "dtStepUs", ",", "1.", ",", "alpha", ",",
             "window"}], "]"}], ",", "nSeg"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nLocal12b", "=", 
        RowBox[{"Take", "[", 
         RowBox[{
          RowBox[{"noiseTrace1fAlpha", "[", 
           RowBox[{
           "1.", ",", "tExpUs", ",", "dtStepUs", ",", "1.", ",", "alpha", ",",
             "window"}], "]"}], ",", "nSeg"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nLocalInt", "=", 
        RowBox[{"Take", "[", 
         RowBox[{
          RowBox[{"noiseTrace1fAlpha", "[", 
           RowBox[{
           "1.", ",", "tExpUs", ",", "dtStepUs", ",", "1.", ",", "alpha", ",",
             "window"}], "]"}], ",", "nSeg"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"n12a", "=", 
        RowBox[{"ampJ12", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Sqrt", "[", "corr", "]"}], " ", "nCommon"}], "+", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", "-", "corr"}], "]"}], " ", "nLocal12a"}]}], 
          ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"n12b", "=", 
        RowBox[{"ampJ12", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Sqrt", "[", "corr", "]"}], " ", "nCommon"}], "+", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", "-", "corr"}], "]"}], " ", "nLocal12b"}]}], 
          ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nint", "=", 
        RowBox[{"ampJint", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Sqrt", "[", "corr", "]"}], " ", "nCommon"}], "+", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", "-", "corr"}], "]"}], " ", "nLocalInt"}]}], 
          ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"U", "=", 
        RowBox[{"Fold", "[", 
         RowBox[{"Dot", ",", 
          RowBox[{"IdentityMatrix", "[", 
           RowBox[{"Length", "[", "HidleFull", "]"}], "]"}], ",", 
          RowBox[{"Reverse", "@", 
           RowBox[{"MapThread", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"MatrixExp", "[", 
               RowBox[{
                RowBox[{"-", "I"}], " ", "2", " ", "Pi", " ", "#1", " ", 
                RowBox[{"(", 
                 RowBox[{"HidleFull", "+", 
                  RowBox[{"j12Idle1", " ", "#2", " ", "HdJ12Full1"}], "+", 
                  RowBox[{"j12Idle2", " ", "#3", " ", "HdJ12Full2"}], "+", 
                  RowBox[{"Jint", " ", 
                   RowBox[{"(", 
                    RowBox[{"1", "+", "#4"}], ")"}], " ", "HintFull"}]}], 
                 ")"}]}], "]"}], "&"}], ",", 
             RowBox[{"{", 
              RowBox[{"dts", ",", "n12a", ",", "n12b", ",", "nint"}], "}"}]}],
             "]"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"K", "=", 
        RowBox[{
         RowBox[{"ConjugateTranspose", "[", "eigtotMatrix", "]"}], ".", "U", ".",
          "eigtotMatrix"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Uid", "=", 
        RowBox[{"Utarget", "[", "Jint", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"fid", "=", 
        RowBox[{"Re", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Tr", "[", 
             RowBox[{
              RowBox[{"ConjugateTranspose", "[", "K", "]"}], ".", "K"}], 
             "]"}], "+", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"Tr", "[", 
               RowBox[{
                RowBox[{"ConjugateTranspose", "[", "Uid", "]"}], ".", "K"}], 
               "]"}], "]"}], "^", "2"}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"d", " ", 
            RowBox[{"(", 
             RowBox[{"d", "+", "1"}], ")"}]}], ")"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"leak", "=", 
        RowBox[{"Re", "[", 
         RowBox[{"1", "-", 
          RowBox[{
           RowBox[{"Tr", "[", 
            RowBox[{
             RowBox[{"ConjugateTranspose", "[", "K", "]"}], ".", "K"}], "]"}],
            "/", "d"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Infidelity\>\"", "->", 
          RowBox[{"1", "-", "fid"}]}], ",", 
         RowBox[{"\"\<Leakage\>\"", "->", "leak"}]}], "|>"}]}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
