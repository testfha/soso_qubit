Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "noiseSpec1f", ",", "noiseTrace1f", ",", "gateDts", ",", "gateData", ",", 
     "oneSample1f", ",", "averagedMetrics1f", ",", "scan1f"}], "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"noiseSpec1f", "[", 
     RowBox[{
      RowBox[{"fLowHz_", ":", "1."}], ",", 
      RowBox[{"fHighHz_", ":", "10.*^6"}], ",", 
      RowBox[{"window_", ":", "20"}]}], "]"}], ":=", 
    RowBox[{
     RowBox[{"noiseSpec1f", "[", 
      RowBox[{"fLowHz", ",", "fHighHz", ",", "window"}], "]"}], "=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "edgesHz", "}"}], ",", 
       RowBox[{
        RowBox[{"edgesHz", "=", 
         RowBox[{"Exp", "@", 
          RowBox[{"Subdivide", "[", 
           RowBox[{
            RowBox[{"Log", "[", "fLowHz", "]"}], ",", 
            RowBox[{"Log", "[", "fHighHz", "]"}], ",", "window"}], "]"}]}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<fMHz\>\"", "->", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{
              RowBox[{"Most", "[", "edgesHz", "]"}], " ", 
              RowBox[{"Rest", "[", "edgesHz", "]"}]}], "]"}], "/", 
            RowBox[{"10.", "^", "6"}]}]}], ",", 
          RowBox[{"\"\<aUnit\>\"", "->", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"Log", "[", 
             RowBox[{
              RowBox[{"Rest", "[", "edgesHz", "]"}], "/", 
              RowBox[{"Most", "[", "edgesHz", "]"}]}], "]"}], "]"}]}]}], 
         "|>"}]}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"noiseTrace1f", "[", 
     RowBox[{
      RowBox[{"nPts_Integer", "?", "Positive"}], ",", "dtStepUs_", ",", 
      "amp1Hz_", ",", "spec_Association"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"phi", ",", "a"}], "}"}], ",", 
      RowBox[{
       RowBox[{"phi", "=", 
        RowBox[{"RandomReal", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
          RowBox[{"Length", "[", 
           RowBox[{"spec", "[", "\"\<fMHz\>\"", "]"}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"a", "=", 
        RowBox[{"amp1Hz", " ", 
         RowBox[{"spec", "[", "\"\<aUnit\>\"", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"a", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{
             RowBox[{"2", " ", "Pi", " ", 
              RowBox[{"spec", "[", "\"\<fMHz\>\"", "]"}], " ", 
              RowBox[{"(", 
               RowBox[{"k", " ", "dtStepUs"}], ")"}]}], "+", "phi"}], "]"}]}],
           "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "0", ",", 
           RowBox[{"nPts", "-", "1"}]}], "}"}]}], "]"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"gateDts", "[", 
     RowBox[{"tg_", ",", "dtStepUs_"}], "]"}], ":=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"n", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"1", ",", 
          RowBox[{"Ceiling", "[", 
           RowBox[{"tg", "/", "dtStepUs"}], "]"}]}], "]"}]}], "}"}], ",", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"ConstantArray", "[", 
         RowBox[{"dtStepUs", ",", 
          RowBox[{"n", "-", "1"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"tg", "-", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"n", "-", "1"}], ")"}], " ", "dtStepUs"}]}], "}"}]}], 
       "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"gateData", "[", 
     RowBox[{
      RowBox[{"Jint_", "?", "NumericQ"}], ",", "dtStepUs_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"gateData", "[", 
      RowBox[{"Jint", ",", "dtStepUs"}], "]"}], "=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"tg", ",", "dts", ",", "Uid"}], "}"}], ",", 
       RowBox[{
        RowBox[{"tg", "=", 
         RowBox[{"tGate", "[", "Jint", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"dts", "=", 
