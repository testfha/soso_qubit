      RowBox[{"{", 
       RowBox[{"Jint", ",", "jintList"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"qsMetricsData", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"With", "[", 
