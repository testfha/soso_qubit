          RowBox[{"tg", ",", "dtStepUs"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Uid", "=", 
         RowBox[{"Utarget", "[", "Jint", "]"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<tgNs\>\"", "->", 
           RowBox[{"1000.", " ", "tg"}]}], ",", 
          RowBox[{"\"\<dts\>\"", "->", "dts"}], ",", 
          RowBox[{"\"\<nSeg\>\"", "->", 
           RowBox[{"Length", "[", "dts", "]"}]}], ",", 
          RowBox[{"\"\<Uid\>\"", "->", "Uid"}]}], "|>"}]}]}], "]"}]}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"oneSample1f", "[", 
     RowBox[{
      RowBox[{"Jint_", "?", "NumericQ"}], ",", "spec_Association", ",", 
      "dtStepUs_", ",", 
      RowBox[{"ampJ12_", ":", 
       RowBox[{"2.5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"ampJint_", ":", 
       RowBox[{"5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "gd", ",", "dts", ",", "nSeg", ",", "n12a", ",", "n12b", ",", "nint", ",",
         "U", ",", "K", ",", "Uid", ",", 
        RowBox[{"d", "=", "4"}], ",", "fid", ",", "leak"}], "}"}], ",", 
      RowBox[{
       RowBox[{"gd", "=", 
        RowBox[{"gateData", "[", 
         RowBox[{"Jint", ",", "dtStepUs"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dts", "=", 
        RowBox[{"gd", "[", "\"\<dts\>\"", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nSeg", "=", 
        RowBox[{"gd", "[", "\"\<nSeg\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Uid", "=", 
        RowBox[{"gd", "[", "\"\<Uid\>\"", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"n12a", "=", 
        RowBox[{"noiseTrace1f", "[", 
         RowBox[{"nSeg", ",", "dtStepUs", ",", "ampJ12", ",", "spec"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"n12b", "=", 
        RowBox[{"noiseTrace1f", "[", 
         RowBox[{"nSeg", ",", "dtStepUs", ",", "ampJ12", ",", "spec"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nint", "=", 
        RowBox[{"noiseTrace1f", "[", 
         RowBox[{"nSeg", ",", "dtStepUs", ",", "ampJint", ",", "spec"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"U", "=", 
        RowBox[{"Fold", "[", 
         RowBox[{"Dot", ",", 
          RowBox[{"IdentityMatrix", "[", 
           RowBox[{"Length", "[", "HidleFull", "]"}], "]"}], ",", 
          RowBox[{"Reverse", "@", 
           RowBox[{"MapThread", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"MatrixExp", "[", 
               RowBox[{
                RowBox[{"-", "I"}], " ", "2", " ", "Pi", " ", "#1", " ", 
                RowBox[{"(", 
                 RowBox[{"HidleFull", "+", 
                  RowBox[{"j12Idle1", " ", "#2", " ", "HdJ12Full1"}], "+", 
                  RowBox[{"j12Idle2", " ", "#3", " ", "HdJ12Full2"}], "+", 
                  RowBox[{"Jint", " ", 
                   RowBox[{"(", 
                    RowBox[{"1", "+", "#4"}], ")"}], " ", "HintFull"}]}], 
                 ")"}]}], "]"}], "&"}], ",", 
             RowBox[{"{", 
              RowBox[{"dts", ",", "n12a", ",", "n12b", ",", "nint"}], "}"}]}],
             "]"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"K", "=", 
        RowBox[{
         RowBox[{"ConjugateTranspose", "[", "eigtotMatrix", "]"}], ".", "U", ".",
          "eigtotMatrix"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"fid", "=", 
        RowBox[{"Re", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Tr", "[", 
             RowBox[{
              RowBox[{"ConjugateTranspose", "[", "K", "]"}], ".", "K"}], 
             "]"}], "+", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"Tr", "[", 
               RowBox[{
                RowBox[{"ConjugateTranspose", "[", "Uid", "]"}], ".", "K"}], 
               "]"}], "]"}], "^", "2"}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"d", " ", 
            RowBox[{"(", 
             RowBox[{"d", "+", "1"}], ")"}]}], ")"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"leak", "=", 
        RowBox[{"Re", "[", 
         RowBox[{"1", "-", 
          RowBox[{
           RowBox[{"Tr", "[", 
            RowBox[{
             RowBox[{"ConjugateTranspose", "[", "K", "]"}], ".", "K"}], "]"}],
            "/", "d"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Infidelity\>\"", "->", 
          RowBox[{"1", "-", "fid"}]}], ",", 
         RowBox[{"\"\<Leakage\>\"", "->", "leak"}]}], "|>"}]}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"averagedMetrics1f", "[", 
     RowBox[{
      RowBox[{"Jint_", "?", "NumericQ"}], ",", "spec_Association", ",", 
      "dtStepUs_", ",", 
      RowBox[{"ampJ12_", ":", 
       RowBox[{"2.5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"ampJint_", ":", 
       RowBox[{"5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"nSamples_", ":", "20"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "samples", "}"}], ",", 
      RowBox[{
       RowBox[{"samples", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"oneSample1f", "[", 
           RowBox[{
           "Jint", ",", "spec", ",", "dtStepUs", ",", "ampJ12", ",", 
            "ampJint"}], "]"}], ",", 
          RowBox[{"{", "nSamples", "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Infidelity\>\"", "->", 
          RowBox[{"Mean", "[", 
           RowBox[{"samples", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "\"\<Infidelity\>\""}], "]"}], "]"}], 
           "]"}]}], ",", 
         RowBox[{"\"\<Leakage\>\"", "->", 
          RowBox[{"Mean", "[", 
           RowBox[{"samples", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "\"\<Leakage\>\""}], "]"}], "]"}], "]"}]}]}],
         "|>"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"scan1f", "[", 
     RowBox[{
     "jGrid_List", ",", "spec_Association", ",", "dtStepUs_", ",", "ampJ12_", 
      ",", "ampJint_", ",", "nSamples_"}], "]"}], ":=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"m", "=", 
           RowBox[{"averagedMetrics1f", "[", 
            RowBox[{
            "Jint", ",", "spec", ",", "dtStepUs", ",", "ampJ12", ",", 
             "ampJint", ",", "nSamples"}], "]"}]}], ",", 
          RowBox[{"tgNs", "=", 
           RowBox[{
            RowBox[{"gateData", "[", 
             RowBox[{"Jint", ",", "dtStepUs"}], "]"}], "[", "\"\<tgNs\>\"", 
            "]"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"tgNs", ",", 
          RowBox[{"m", "[", "\"\<Infidelity\>\"", "]"}], ",", 
          RowBox[{"m", "[", "\"\<Leakage\>\"", "]"}], ",", "Jint"}], "}"}]}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"Jint", ",", "jGrid"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"ampJ12", "=", 
   RowBox[{"2.5", "*", 
    RowBox[{"10", "^", 
     RowBox[{"-", "4"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ampJint", "=", 
    RowBox[{"5", "*", 
     RowBox[{"10", "^", 
      RowBox[{"-", "4"}]}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"fast", " ", "first", " ", "pass"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dtStepUs", "=", "0.001"}], ";"}], "     ", 
  RowBox[{"(*", 
   RowBox[{"1", " ", "ns"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"fLowHz", "=", "1."}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fHighHz", "=", "10.*^6"}], ";"}], "     ", 
  RowBox[{"(*", 
   RowBox[{"10", " ", "MHz"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"window", "=", "50"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"nSamples", "=", "200"}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"production", " ", "example", " ", "dtStepUs"}], "=", "0.001"}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"fLowHz", "=", "1."}], ";", "\[IndentingNewLine]", 
    RowBox[{"fHighHz", "=", "30.*^6"}], ";", "\[IndentingNewLine]", 
    RowBox[{"window", "=", "40"}], ";", "\[IndentingNewLine]", 
    RowBox[{"nSamples", "=", "100"}], ";"}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"spec", "=", 
   RowBox[{"noiseSpec1f", "[", 
    RowBox[{"fLowHz", ",", "fHighHz", ",", "window"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"jGrid", "=", 
    RowBox[{"Range", "[", 
     RowBox[{"jintMin", ",", "jintMax", ",", "djint"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"metrics1fData", "=", 
    RowBox[{"scan1f", "[", 
     RowBox[{
     "jGrid", ",", "spec", ",", "dtStepUs", ",", "ampJ12", ",", "ampJint", ",",
       "nSamples"}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"infidelity1fData", "=", 
   RowBox[{"metrics1fData", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
