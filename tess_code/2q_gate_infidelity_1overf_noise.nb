Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "noiseSpec1f", ",", "noiseTrace1f", ",", "gateDts", ",", "gateData", ",", 
     "oneSample1f", ",", "averagedMetrics1f", ",", "scan1f"}], "]"}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"noiseSpec1f", "[", 
     RowBox[{
      RowBox[{"fLowHz_", ":", "1."}], ",", 
      RowBox[{"fHighHz_", ":", "10.*^6"}], ",", 
      RowBox[{"window_", ":", "20"}]}], "]"}], ":=", 
    RowBox[{
     RowBox[{"noiseSpec1f", "[", 
      RowBox[{"fLowHz", ",", "fHighHz", ",", "window"}], "]"}], "=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "edgesHz", "}"}], ",", 
       RowBox[{
        RowBox[{"edgesHz", "=", 
         RowBox[{"Exp", "@", 
          RowBox[{"Subdivide", "[", 
           RowBox[{
            RowBox[{"Log", "[", "fLowHz", "]"}], ",", 
            RowBox[{"Log", "[", "fHighHz", "]"}], ",", "window"}], "]"}]}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<fMHz\>\"", "->", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{
              RowBox[{"Most", "[", "edgesHz", "]"}], " ", 
              RowBox[{"Rest", "[", "edgesHz", "]"}]}], "]"}], "/", 
            RowBox[{"10.", "^", "6"}]}]}], ",", 
          RowBox[{"\"\<aUnit\>\"", "->", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"Log", "[", 
             RowBox[{
              RowBox[{"Rest", "[", "edgesHz", "]"}], "/", 
              RowBox[{"Most", "[", "edgesHz", "]"}]}], "]"}], "]"}]}]}], 
         "|>"}]}]}], "]"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"noiseTrace1f", "[", 
     RowBox[{
      RowBox[{"nPts_Integer", "?", "Positive"}], ",", "dtStepUs_", ",", 
      "amp1Hz_", ",", "spec_Association"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"phi", ",", "a"}], "}"}], ",", 
      RowBox[{
       RowBox[{"phi", "=", 
        RowBox[{"RandomReal", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
          RowBox[{"Length", "[", 
           RowBox[{"spec", "[", "\"\<fMHz\>\"", "]"}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"a", "=", 
        RowBox[{"amp1Hz", " ", 
         RowBox[{"spec", "[", "\"\<aUnit\>\"", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"a", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{
             RowBox[{"2", " ", "Pi", " ", 
              RowBox[{"spec", "[", "\"\<fMHz\>\"", "]"}], " ", 
              RowBox[{"(", 
               RowBox[{"k", " ", "dtStepUs"}], ")"}]}], "+", "phi"}], "]"}]}],
           "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "0", ",", 
           RowBox[{"nPts", "-", "1"}]}], "}"}]}], "]"}]}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"gateDts", "[", 
     RowBox[{"tg_", ",", "dtStepUs_"}], "]"}], ":=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"n", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"1", ",", 
          RowBox[{"Ceiling", "[", 
           RowBox[{"tg", "/", "dtStepUs"}], "]"}]}], "]"}]}], "}"}], ",", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"ConstantArray", "[", 
         RowBox[{"dtStepUs", ",", 
          RowBox[{"n", "-", "1"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"tg", "-", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"n", "-", "1"}], ")"}], " ", "dtStepUs"}]}], "}"}]}], 
       "]"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"gateData", "[", 
     RowBox[{
      RowBox[{"Jint_", "?", "NumericQ"}], ",", "dtStepUs_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"gateData", "[", 
      RowBox[{"Jint", ",", "dtStepUs"}], "]"}], "=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"tg", ",", "dts", ",", "Uid"}], "}"}], ",", 
       RowBox[{
        RowBox[{"tg", "=", 
         RowBox[{"tGate", "[", "Jint", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"dts", "=", 
         RowBox[{"gateDts", "[", 
          RowBox[{"tg", ",", "dtStepUs"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Uid", "=", 
         RowBox[{"Utarget", "[", "Jint", "]"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<tgNs\>\"", "->", 
           RowBox[{"1000.", " ", "tg"}]}], ",", 
          RowBox[{"\"\<dts\>\"", "->", "dts"}], ",", 
          RowBox[{"\"\<nSeg\>\"", "->", 
           RowBox[{"Length", "[", "dts", "]"}]}], ",", 
          RowBox[{"\"\<Uid\>\"", "->", "Uid"}]}], "|>"}]}]}], "]"}]}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"oneSample1f", "[", 
     RowBox[{
      RowBox[{"Jint_", "?", "NumericQ"}], ",", "spec_Association", ",", 
      "dtStepUs_", ",", 
      RowBox[{"ampJ12_", ":", 
       RowBox[{"2.5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"ampJint_", ":", 
       RowBox[{"5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "gd", ",", "dts", ",", "nSeg", ",", "n12a", ",", "n12b", ",", "nint", ",",
         "U", ",", "K", ",", "Uid", ",", 
        RowBox[{"d", "=", "4"}], ",", "fid", ",", "leak"}], "}"}], ",", 
      RowBox[{
       RowBox[{"gd", "=", 
        RowBox[{"gateData", "[", 
         RowBox[{"Jint", ",", "dtStepUs"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dts", "=", 
        RowBox[{"gd", "[", "\"\<dts\>\"", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nSeg", "=", 
        RowBox[{"gd", "[", "\"\<nSeg\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Uid", "=", 
        RowBox[{"gd", "[", "\"\<Uid\>\"", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"n12a", "=", 
        RowBox[{"noiseTrace1f", "[", 
         RowBox[{"nSeg", ",", "dtStepUs", ",", "ampJ12", ",", "spec"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"n12b", "=", 
        RowBox[{"noiseTrace1f", "[", 
         RowBox[{"nSeg", ",", "dtStepUs", ",", "ampJ12", ",", "spec"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nint", "=", 
        RowBox[{"noiseTrace1f", "[", 
         RowBox[{"nSeg", ",", "dtStepUs", ",", "ampJint", ",", "spec"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"U", "=", 
        RowBox[{"Fold", "[", 
         RowBox[{"Dot", ",", 
          RowBox[{"IdentityMatrix", "[", 
           RowBox[{"Length", "[", "HidleFull", "]"}], "]"}], ",", 
          RowBox[{"Reverse", "@", 
           RowBox[{"MapThread", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"MatrixExp", "[", 
               RowBox[{
                RowBox[{"-", "I"}], " ", "2", " ", "Pi", " ", "#1", " ", 
                RowBox[{"(", 
                 RowBox[{"HidleFull", "+", 
                  RowBox[{"j12Idle1", " ", "#2", " ", "HdJ12Full1"}], "+", 
                  RowBox[{"j12Idle2", " ", "#3", " ", "HdJ12Full2"}], "+", 
                  RowBox[{"Jint", " ", 
                   RowBox[{"(", 
                    RowBox[{"1", "+", "#4"}], ")"}], " ", "HintFull"}]}], 
                 ")"}]}], "]"}], "&"}], ",", 
             RowBox[{"{", 
              RowBox[{"dts", ",", "n12a", ",", "n12b", ",", "nint"}], "}"}]}],
             "]"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"K", "=", 
        RowBox[{
         RowBox[{"ConjugateTranspose", "[", "eigtotMatrix", "]"}], ".", "U", ".",
          "eigtotMatrix"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"fid", "=", 
        RowBox[{"Re", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Tr", "[", 
             RowBox[{
              RowBox[{"ConjugateTranspose", "[", "K", "]"}], ".", "K"}], 
             "]"}], "+", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"Tr", "[", 
               RowBox[{
                RowBox[{"ConjugateTranspose", "[", "Uid", "]"}], ".", "K"}], 
               "]"}], "]"}], "^", "2"}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"d", " ", 
            RowBox[{"(", 
             RowBox[{"d", "+", "1"}], ")"}]}], ")"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"leak", "=", 
        RowBox[{"Re", "[", 
         RowBox[{"1", "-", 
          RowBox[{
           RowBox[{"Tr", "[", 
            RowBox[{
             RowBox[{"ConjugateTranspose", "[", "K", "]"}], ".", "K"}], "]"}],
            "/", "d"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Infidelity\>\"", "->", 
          RowBox[{"1", "-", "fid"}]}], ",", 
         RowBox[{"\"\<Leakage\>\"", "->", "leak"}]}], "|>"}]}]}], "]"}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"averagedMetrics1f", "[", 
     RowBox[{
      RowBox[{"Jint_", "?", "NumericQ"}], ",", "spec_Association", ",", 
      "dtStepUs_", ",", 
      RowBox[{"ampJ12_", ":", 
       RowBox[{"2.5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"ampJint_", ":", 
       RowBox[{"5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"nSamples_", ":", "20"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "samples", "}"}], ",", 
      RowBox[{
       RowBox[{"samples", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"oneSample1f", "[", 
           RowBox[{
           "Jint", ",", "spec", ",", "dtStepUs", ",", "ampJ12", ",", 
            "ampJint"}], "]"}], ",", 
          RowBox[{"{", "nSamples", "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Infidelity\>\"", "->", 
          RowBox[{"Mean", "[", 
           RowBox[{"samples", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "\"\<Infidelity\>\""}], "]"}], "]"}], 
           "]"}]}], ",", 
         RowBox[{"\"\<Leakage\>\"", "->", 
          RowBox[{"Mean", "[", 
           RowBox[{"samples", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "\"\<Leakage\>\""}], "]"}], "]"}], "]"}]}]}],
         "|>"}]}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"scan1f", "[", 
     RowBox[{
     "jGrid_List", ",", "spec_Association", ",", "dtStepUs_", ",", "ampJ12_", 
      ",", "ampJint_", ",", "nSamples_"}], "]"}], ":=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"m", "=", 
           RowBox[{"averagedMetrics1f", "[", 
            RowBox[{
            "Jint", ",", "spec", ",", "dtStepUs", ",", "ampJ12", ",", 
             "ampJint", ",", "nSamples"}], "]"}]}], ",", 
          RowBox[{"tgNs", "=", 
           RowBox[{
            RowBox[{"gateData", "[", 
             RowBox[{"Jint", ",", "dtStepUs"}], "]"}], "[", "\"\<tgNs\>\"", 
            "]"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"tgNs", ",", 
          RowBox[{"m", "[", "\"\<Infidelity\>\"", "]"}], ",", 
          RowBox[{"m", "[", "\"\<Leakage\>\"", "]"}], ",", "Jint"}], "}"}]}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"Jint", ",", "jGrid"}], "}"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ampJ12", "=", 
   RowBox[{"2.5", "*", 
    RowBox[{"10", "^", 
     RowBox[{"-", "4"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ampJint", "=", 
