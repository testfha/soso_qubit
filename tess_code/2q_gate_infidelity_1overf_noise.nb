   RowBox[{"leakage1fData", "=", 
    RowBox[{"metrics1fData", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "3"}], "}"}]}], "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"ListLogPlot", "[", 
   RowBox[{
    RowBox[{"{", "infidelity1fData", "}"}], ",", 
    RowBox[{"Frame", "->", "True"}], ",", 
