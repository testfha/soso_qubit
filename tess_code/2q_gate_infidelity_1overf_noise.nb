Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "noiseTrace1f", ",", "U1fCorr", ",", "K1fCorr", ",", 
     "gateInfidelity1fCorrSample", ",", "gateInfidelity1fCorrMean"}], "]"}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"noiseTrace1f", "[", 
     RowBox[{
      RowBox[{"tg_", "?", "NumericQ"}], ",", 
      RowBox[{"nSteps_", ":", "64"}], ",", 
      RowBox[{"amp1Hz_", ":", "0."}], ",", 
      RowBox[{"alpha_", ":", "1."}], ",", 
      RowBox[{"window_", ":", "100"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "tObs", ",", "dt", ",", "df", ",", "t", ",", "f", ",", "phi", ",", 
        "a"}], "}"}], ",", 
      RowBox[{
       RowBox[{"tObs", "=", 
        RowBox[{"window", " ", "tg"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"dt", "=", 
        RowBox[{"tg", "/", "nSteps"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"df", "=", 
        RowBox[{"1.", "/", "tObs"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"t", "=", 
        RowBox[{
         RowBox[{"Range", "[", 
          RowBox[{"0", ",", 
           RowBox[{"nSteps", "-", "1"}]}], "]"}], " ", "dt"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"f", "=", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{"Range", "[", 
           RowBox[{"1", ",", 
            RowBox[{"Floor", "[", 
             RowBox[{"window", " ", 
              RowBox[{"nSteps", "/", "2"}]}], "]"}]}], "]"}], " ", "df"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"phi", "=", 
        RowBox[{"RandomReal", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
          RowBox[{"Length", "[", "f", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"a", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"amp1Hz", "^", "2"}], "/", 
            RowBox[{"f", "^", "alpha"}]}], ")"}], " ", "df"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"a", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{
             RowBox[{"2", " ", "Pi", " ", "f", " ", "tk"}], "+", "phi"}], 
            "]"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"tk", ",", "t"}], "}"}]}], "]"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"U1fCorr", "[", 
     RowBox[{
      RowBox[{"Jint_", "?", "NumericQ"}], ",", 
      RowBox[{"ampJ12_", ":", 
       RowBox[{"2.5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"ampJint_", ":", 
       RowBox[{"5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"corr_", ":", "0.5"}], ",", 
      RowBox[{"nSteps_", ":", "64"}], ",", 
      RowBox[{"alpha_", ":", "1."}], ",", 
      RowBox[{"window_", ":", "100"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "tg", ",", "dt", ",", "nCommon", ",", "nLocal12a", ",", "nLocal12b", ",",
         "nLocalInt", ",", "n12a", ",", "n12b", ",", "nint", ",", "steps", ",",
         "dim"}], "}"}], ",", 
      RowBox[{
       RowBox[{"tg", "=", 
        RowBox[{"tGate", "[", "Jint", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"dt", "=", 
        RowBox[{"tg", "/", "nSteps"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nCommon", "=", 
        RowBox[{"noiseTrace1f", "[", 
         RowBox[{
         "tg", ",", "nSteps", ",", "1.", ",", "alpha", ",", "window"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nLocal12a", "=", 
        RowBox[{"noiseTrace1f", "[", 
         RowBox[{
         "tg", ",", "nSteps", ",", "1.", ",", "alpha", ",", "window"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nLocal12b", "=", 
        RowBox[{"noiseTrace1f", "[", 
         RowBox[{
         "tg", ",", "nSteps", ",", "1.", ",", "alpha", ",", "window"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nLocalInt", "=", 
        RowBox[{"noiseTrace1f", "[", 
         RowBox[{
         "tg", ",", "nSteps", ",", "1.", ",", "alpha", ",", "window"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"n12a", "=", 
        RowBox[{"ampJ12", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Sqrt", "[", "corr", "]"}], " ", "nCommon"}], "+", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", "-", "corr"}], "]"}], " ", "nLocal12a"}]}], 
          ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"n12b", "=", 
        RowBox[{"ampJ12", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Sqrt", "[", "corr", "]"}], " ", "nCommon"}], "+", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", "-", "corr"}], "]"}], " ", "nLocal12b"}]}], 
          ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nint", "=", 
        RowBox[{"ampJint", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Sqrt", "[", "corr", "]"}], " ", "nCommon"}], "+", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", "-", "corr"}], "]"}], " ", "nLocalInt"}]}], 
          ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"dim", "=", 
        RowBox[{"Length", "[", "HidleFull", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"steps", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"MatrixExp", "[", 
           RowBox[{
            RowBox[{"-", "I"}], " ", "2", " ", "Pi", " ", "dt", " ", 
            RowBox[{"(", 
             RowBox[{"HidleFull", "+", 
              RowBox[{"j12Idle1", " ", 
               RowBox[{"n12a", "[", 
                RowBox[{"[", "k", "]"}], "]"}], " ", "HdJ12Full1"}], "+", 
              RowBox[{"j12Idle2", " ", 
               RowBox[{"n12b", "[", 
                RowBox[{"[", "k", "]"}], "]"}], " ", "HdJ12Full2"}], "+", 
              RowBox[{"Jint", " ", 
               RowBox[{"(", 
                RowBox[{"1", "+", 
                 RowBox[{"nint", "[", 
                  RowBox[{"[", "k", "]"}], "]"}]}], ")"}], " ", 
               "HintFull"}]}], ")"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "nSteps"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Fold", "[", 
        RowBox[{"Dot", ",", 
         RowBox[{"IdentityMatrix", "[", "dim", "]"}], ",", 
         RowBox[{"Reverse", "[", "steps", "]"}]}], "]"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"K1fCorr", "[", 
     RowBox[{
      RowBox[{"Jint_", "?", "NumericQ"}], ",", 
      RowBox[{"ampJ12_", ":", 
       RowBox[{"2.5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"ampJint_", ":", 
       RowBox[{"5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"corr_", ":", "0.5"}], ",", 
      RowBox[{"nSteps_", ":", "64"}], ",", 
      RowBox[{"alpha_", ":", "1."}], ",", 
      RowBox[{"window_", ":", "100"}]}], "]"}], ":=", 
    RowBox[{
     RowBox[{"ConjugateTranspose", "[", "eigtotMatrix", "]"}], ".", 
     RowBox[{"U1fCorr", "[", 
      RowBox[{
      "Jint", ",", "ampJ12", ",", "ampJint", ",", "corr", ",", "nSteps", ",", 
       "alpha", ",", "window"}], "]"}], ".", "eigtotMatrix"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"gateInfidelity1fCorrSample", "[", 
     RowBox[{
      RowBox[{"Jint_", "?", "NumericQ"}], ",", 
      RowBox[{"ampJ12_", ":", 
       RowBox[{"2.5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"ampJint_", ":", 
       RowBox[{"5", "*", 
        RowBox[{"10", "^", 
         RowBox[{"-", "4"}]}]}]}], ",", 
      RowBox[{"corr_", ":", "0.5"}], ",", 
      RowBox[{"nSteps_", ":", "64"}], ",", 
      RowBox[{"alpha_", ":", "1."}], ",", 
      RowBox[{"window_", ":", "100"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"K", ",", "Uid", ",", 
        RowBox[{"d", "=", "4"}], ",", "fid"}], "}"}], ",", 
      RowBox[{
       RowBox[{"K", "=", 
        RowBox[{"K1fCorr", "[", 
         RowBox[{
         "Jint", ",", "ampJ12", ",", "ampJint", ",", "corr", ",", "nSteps", ",",
           "alpha", ",", "window"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Uid", "=", 
        RowBox[{"Utarget", "[", "Jint", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"fid", "=", 
        RowBox[{"Re", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Tr", "[", 
             RowBox[{
              RowBox[{"ConjugateTranspose", "[", "K", "]"}], ".", "K"}], 
             "]"}], "+", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"Tr", "[", 
               RowBox[{
                RowBox[{"ConjugateTranspose", "[", "Uid", "]"}], ".", "K"}], 
               "]"}], "]"}], "^", "2"}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"d", " ", 
            RowBox[{"(", 
             RowBox[{"d", "+", "1"}], ")"}]}], ")"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"1", "-", "fid"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
