Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "HdJ12Q1", ",", "HdJ12Q2", ",", "HdJ12Full1", ",", "HdJ12Full2", ",", 
     "HintFull", ",", "UprojQS", ",", "oneSampleQS", ",", 
     "averagedMetricsQS"}], "]"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"HdJ12Q1", "=", 
    RowBox[{
     RowBox[{"N", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "4"}], ")"}], " ", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Rot1", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "j"}], "]"}], "]"}], " ", 
           RowBox[{"KroneckerProduct", "[", 
            RowBox[{
             RowBox[{"PauliMatrix", "[", "i", "]"}], ",", 
             RowBox[{"PauliMatrix", "[", "j", "]"}], ",", 
             RowBox[{"PauliMatrix", "[", "0", "]"}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "3"}], "}"}]}], "]"}]}], "/.", " ", 
       "pars1"}], "]"}], "//", "Chop"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"HdJ12Q2", "=", 
    RowBox[{
     RowBox[{"N", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "4"}], ")"}], " ", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Rot1", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "j"}], "]"}], "]"}], " ", 
           RowBox[{"KroneckerProduct", "[", 
            RowBox[{
             RowBox[{"PauliMatrix", "[", "i", "]"}], ",", 
             RowBox[{"PauliMatrix", "[", "j", "]"}], ",", 
             RowBox[{"PauliMatrix", "[", "0", "]"}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "3"}], "}"}]}], "]"}]}], "/.", " ", 
       "pars2"}], "]"}], "//", "Chop"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"HdJ12Full1", "=", 
   RowBox[{"KroneckerProduct", "[", 
    RowBox[{"HdJ12Q1", ",", 
     RowBox[{"IdentityMatrix", "[", "8", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"HdJ12Full2", "=", 
   RowBox[{"KroneckerProduct", "[", 
    RowBox[{
     RowBox[{"IdentityMatrix", "[", "8", "]"}], ",", "HdJ12Q2"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"HintFull", "=", 
    RowBox[{
     RowBox[{"N", "[", 
      RowBox[{"Hint", "[", "1.0", "]"}], "]"}], "//", "Chop"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"sigmaJ12QS", "=", 
   RowBox[{"5.3", "*", 
    RowBox[{"10", "^", 
     RowBox[{"-", "4"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"sigmaJintQS", "=", 
    RowBox[{"1.06", "*", 
     RowBox[{"10", "^", 
      RowBox[{"-", "3"}]}]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"UprojQS", "[", 
     RowBox[{"Jint_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "tg", ",", "d1", ",", "d2", ",", "dint", ",", "Hnoisy", ",", "U"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"tg", "=", 
        RowBox[{"tGate", "[", "Jint", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"d1", "=", 
        RowBox[{"RandomVariate", "[", 
         RowBox[{"NormalDistribution", "[", 
          RowBox[{"0", ",", "sigmaJ12QS"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"d2", "=", 
        RowBox[{"RandomVariate", "[", 
         RowBox[{"NormalDistribution", "[", 
          RowBox[{"0", ",", "sigmaJ12QS"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dint", "=", 
        RowBox[{"RandomVariate", "[", 
         RowBox[{"NormalDistribution", "[", 
          RowBox[{"0", ",", "sigmaJintQS"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Hnoisy", "=", 
        RowBox[{"HidleFull", "+", 
         RowBox[{"j12Idle1", " ", "d1", " ", "HdJ12Full1"}], "+", 
         RowBox[{"j12Idle2", " ", "d2", " ", "HdJ12Full2"}], "+", 
         RowBox[{"Jint", " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", "dint"}], ")"}], " ", "HintFull"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"U", "=", 
        RowBox[{"MatrixExp", "[", 
         RowBox[{
          RowBox[{"-", "I"}], " ", "2", " ", "Pi", " ", "Hnoisy", " ", "tg"}],
          "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ConjugateTranspose", "[", "eigtotMatrix", "]"}], ".", "U", ".",
         "eigtotMatrix"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 

 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"oneSampleQS", "[", 
     RowBox[{"Jint_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"K", ",", "Uid", ",", 
        RowBox[{"d", "=", "4"}], ",", "fidelity", ",", "leakage"}], "}"}], ",", 
      RowBox[{
       RowBox[{"K", "=", 
        RowBox[{"UprojQS", "[", "Jint", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Uid", "=", 
        RowBox[{"Utarget", "[", "Jint", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"fidelity", "=", 
        RowBox[{"Re", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Tr", "[", 
             RowBox[{
              RowBox[{"ConjugateTranspose", "[", "K", "]"}], ".", "K"}], 
             "]"}], "+", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"Tr", "[", 
               RowBox[{
                RowBox[{"ConjugateTranspose", "[", "Uid", "]"}], ".", "K"}], 
               "]"}], "]"}], "^", "2"}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"d", " ", 
            RowBox[{"(", 
             RowBox[{"d", "+", "1"}], ")"}]}], ")"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"leakage", "=", 
        RowBox[{"Re", "[", 
         RowBox[{"1", "-", 
          RowBox[{
           RowBox[{"Tr", "[", 
            RowBox[{
             RowBox[{"ConjugateTranspose", "[", "K", "]"}], ".", "K"}], "]"}],
            "/", "d"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Infidelity\>\"", "->", 
          RowBox[{"1", "-", "fidelity"}]}], ",", 
         RowBox[{"\"\<Leakage\>\"", "->", "leakage"}]}], "|>"}]}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"averagedMetricsQS", "[", 
     RowBox[{
      RowBox[{"Jint_", "?", "NumericQ"}], ",", 
      RowBox[{"nSamples_", ":", "200"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "samples", "}"}], ",", 
      RowBox[{
       RowBox[{"samples", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"oneSampleQS", "[", "Jint", "]"}], ",", 
          RowBox[{"{", "nSamples", "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Infidelity\>\"", "->", 
          RowBox[{"Mean", "[", 
           RowBox[{"samples", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "\"\<Infidelity\>\""}], "]"}], "]"}], 
           "]"}]}], ",", 
         RowBox[{"\"\<Leakage\>\"", "->", 
          RowBox[{"Mean", "[", 
           RowBox[{"samples", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "\"\<Leakage\>\""}], "]"}], "]"}], "]"}]}]}],
         "|>"}]}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nSampQS", "=", "200"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "jFromTGateNs", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"jFromTGateNs", "[", 
     RowBox[{"tgNs_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"tg", "=", 
        RowBox[{"tgNs", "/", "1000."}]}], "}"}], ",", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"tg", "^", "2"}]}], "-", 
        RowBox[{"Delta", "^", "2"}]}], "]"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
