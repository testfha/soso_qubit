Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"J12", " ", "leakage"}], "-", 
    RowBox[{"refocused", " ", "target"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Omega12", "[", "dJ12_", "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"DeltaL", "^", "2"}], "-", 
       RowBox[{"4", " ", "eta", " ", "DeltaL", " ", 
        RowBox[{"dJ12", "/", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"eta", "^", "2"}]}], ")"}]}]}], "+", 
       RowBox[{"dJ12", "^", "2"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"t12", "[", 
      RowBox[{"dJ12_", ",", 
       RowBox[{"n_", ":", "1"}]}], "]"}], ":=", 
     RowBox[{"n", "/", 
      RowBox[{"Omega12", "[", "dJ12", "]"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"E120", "[", "dJ12_", "]"}], ":=", 
     RowBox[{"dJ12", "/", "4"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"E121", "[", "dJ12_", "]"}], ":=", 
     RowBox[{"dJ12", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "1"}], "/", "4"}], "+", 
        RowBox[{"eta", "/", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"eta", "^", "2"}]}], ")"}]}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"E12L", "[", "dJ12_", "]"}], ":=", 
     RowBox[{"DeltaL", "+", 
      RowBox[{"dJ12", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "1"}], "/", "4"}], "-", 
         RowBox[{"eta", "/", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"eta", "^", "2"}]}], ")"}]}]}], ")"}]}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Utarget12", "[", 
      RowBox[{"dJ12_", ",", 
       RowBox[{"n_", ":", "1"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", ",", "phi0", ",", "phi1"}], "}"}], ",", 
       RowBox[{
        RowBox[{"t", "=", 
         RowBox[{"t12", "[", 
          RowBox[{"dJ12", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"phi0", "=", 
         RowBox[{
          RowBox[{"E120", "[", "dJ12", "]"}], " ", "t"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"phi1", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"E121", "[", "dJ12", "]"}], "+", 
               RowBox[{"E12L", "[", "dJ12", "]"}]}], ")"}], "/", "2"}], ")"}],
            " ", "t"}], "+", 
          RowBox[{"n", "/", "2"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"DiagonalMatrix", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "2", " ", "Pi", " ", "phi0"}], "]"}], ",", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "2", " ", "Pi", " ", "phi1"}], "]"}]}], 
          "}"}], "]"}]}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"metric12", "[", 
      RowBox[{"dJ12_", ",", 
       RowBox[{"n_", ":", "1"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", ",", "K", ",", "Uid"}], "}"}], ",", 
       RowBox[{
        RowBox[{"t", "=", 
         RowBox[{"t12", "[", 
          RowBox[{"dJ12", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"K", "=", 
         RowBox[{"Uproj", "[", 
          RowBox[{"dJ12", ",", "0", ",", "t"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Uid", "=", 
         RowBox[{"Utarget12", "[", 
          RowBox[{"dJ12", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"1000", " ", "t"}], ",", 
          RowBox[{"floor", "[", 
           RowBox[{"infid", "[", 
            RowBox[{"K", ",", "Uid"}], "]"}], "]"}], ",", 
          RowBox[{"floor", "[", 
           RowBox[{"leak", "[", "K", "]"}], "]"}], ",", "dJ12"}], "}"}]}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"data12", "=", 
     RowBox[{"ParallelTable", "[", 
      RowBox[{
       RowBox[{"metric12", "[", 
        RowBox[{"dJ12", ",", "1"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"dJ12", ",", 
         RowBox[{"Range", "[", 
          RowBox[{
           RowBox[{"-", "40"}], ",", 
           RowBox[{"-", "0.1"}], ",", "0.05"}], "]"}]}], "}"}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"ListLogPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"data12", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}], ",", 
       RowBox[{"data12", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "3"}], "}"}]}], "]"}], "]"}]}], "}"}], ",", 
     RowBox[{"Joined", "->", "True"}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<t_g [ns]\>\"", ",", "\"\<Error\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<infidelity\>\"", ",", "\"\<leakage\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<J12 leakage-refocused gate\>\""}], ",", 
     RowBox[{"ImageSize", "->", "Large"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9875029802344627`*^9, 3.987502980236586*^9}},
 CellLabel->"In[53]:=",ExpressionUUID->"979fb949-b027-4aa7-bff0-66ca7283f7cf"],

