Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"J23", " ", "leakage"}], "-", 
    RowBox[{"refocused", " ", "target"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Omega23", "[", "dJ23_", "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"DeltaL", "^", "2"}], "+", 
       RowBox[{"2", " ", "DeltaL", " ", 
        RowBox[{"dJ23", "/", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"eta", "^", "2"}]}], ")"}]}]}], "+", 
       RowBox[{"dJ23", "^", "2"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"t23", "[", 
      RowBox[{"dJ23_", ",", 
       RowBox[{"n_", ":", "1"}]}], "]"}], ":=", 
     RowBox[{"n", "/", 
      RowBox[{"Omega23", "[", "dJ23", "]"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"E23D", "[", "dJ23_", "]"}], ":=", 
     RowBox[{"dJ23", "/", "4"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"E23B", "[", "dJ23_", "]"}], ":=", 
     RowBox[{
      RowBox[{"-", "dJ23"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"eta", "^", "2"}], "+", "3"}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", " ", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"eta", "^", "2"}]}], ")"}]}], ")"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"E23L", "[", "dJ23_", "]"}], ":=", 
     RowBox[{"DeltaL", "+", 
      RowBox[{"dJ23", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"eta", "^", "2"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"4", " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"eta", "^", "2"}]}], ")"}]}], ")"}]}]}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Utarget23", "[", 
      RowBox[{"dJ23_", ",", 
       RowBox[{"n_", ":", "1"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", ",", "phiB", ",", "phiD"}], "}"}], ",", 
       RowBox[{
        RowBox[{"t", "=", 
         RowBox[{"t23", "[", 
          RowBox[{"dJ23", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"phiD", "=", 
         RowBox[{
          RowBox[{"E23D", "[", "dJ23", "]"}], " ", "t"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"phiB", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"E23B", "[", "dJ23", "]"}], "+", 
               RowBox[{"E23L", "[", "dJ23", "]"}]}], ")"}], "/", "2"}], ")"}],
            " ", "t"}], "+", 
          RowBox[{"n", "/", "2"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "I"}], " ", "2", " ", "Pi", " ", "phiB"}], "]"}], " ",
           "PB"}], "+", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "I"}], " ", "2", " ", "Pi", " ", "phiD"}], "]"}], " ",
           "PD"}]}]}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"metric23", "[", 
      RowBox[{"dJ23_", ",", 
       RowBox[{"n_", ":", "1"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", ",", "K", ",", "Uid"}], "}"}], ",", 
       RowBox[{
        RowBox[{"t", "=", 
         RowBox[{"t23", "[", 
          RowBox[{"dJ23", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"K", "=", 
         RowBox[{"Uproj", "[", 
          RowBox[{"0", ",", "dJ23", ",", "t"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Uid", "=", 
         RowBox[{"Utarget23", "[", 
          RowBox[{"dJ23", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"1000", " ", "t"}], ",", 
          RowBox[{"floor", "[", 
           RowBox[{"infid", "[", 
            RowBox[{"K", ",", "Uid"}], "]"}], "]"}], ",", 
          RowBox[{"floor", "[", 
           RowBox[{"leak", "[", "K", "]"}], "]"}], ",", "dJ23"}], "}"}]}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"data23", "=", 
     RowBox[{"ParallelTable", "[", 
      RowBox[{
       RowBox[{"metric23", "[", 
        RowBox[{"dJ23", ",", "1"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"dJ23", ",", 
         RowBox[{"Range", "[", 
          RowBox[{"0.1", ",", "40", ",", "0.05"}], "]"}]}], "}"}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"ListLogPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"data23", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}], ",", 
       RowBox[{"data23", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "3"}], "}"}]}], "]"}], "]"}]}], "}"}], ",", 
     RowBox[{"Joined", "->", "True"}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<t_g [ns]\>\"", ",", "\"\<Error\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<infidelity\>\"", ",", "\"\<leakage\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<J23 leakage-refocused gate\>\""}], ",", 
     RowBox[{"ImageSize", "->", "Large"}]}], "]"}]}]}]], "Input",
