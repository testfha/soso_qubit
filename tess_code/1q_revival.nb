Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Log", "-", 
    RowBox[{"binned", " ", 
     RowBox[{"1", "/", "f"}], " ", "noise", " ", "on", " ", "a", " ", "fixed",
      " ", "experimental", " ", "window"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{
     "noiseTrace1f", ",", "gateDts", ",", "sample23", ",", "sample12", ",", 
      "avg23", ",", "avg12", ",", "wrapHalf", ",", "revPhase", ",", 
      "xCoeff23", ",", "zCoeff12", ",", "findPoint"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"noiseTrace1f", "[", 
      RowBox[{"amp_", ",", 
       RowBox[{"tExpUs_", ":", "1."}], ",", 
       RowBox[{"dtStepUs_", ":", "0.0005"}], ",", 
       RowBox[{"fLowHz_", ":", "1."}], ",", 
       RowBox[{"window_", ":", "200"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "nPts", ",", "fLowMHz", ",", "fNyqMHz", ",", "edgesMHz", ",", "fMHz", 
         ",", "phi", ",", "a"}], "}"}], ",", 
       RowBox[{
        RowBox[{"nPts", "=", 
         RowBox[{"Ceiling", "[", 
          RowBox[{"tExpUs", "/", "dtStepUs"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"fLowMHz", "=", 
         RowBox[{
          RowBox[{"10", "^", 
           RowBox[{"-", "6"}]}], " ", "fLowHz"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"fNyqMHz", "=", 
         RowBox[{"1", "/", 
          RowBox[{"(", 
           RowBox[{"2", " ", "dtStepUs"}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"edgesMHz", "=", 
         RowBox[{"Exp", "@", 
          RowBox[{"Subdivide", "[", 
           RowBox[{
            RowBox[{"Log", "[", "fLowMHz", "]"}], ",", 
            RowBox[{"Log", "[", "fNyqMHz", "]"}], ",", "window"}], "]"}]}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"fMHz", "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"Most", "[", "edgesMHz", "]"}], " ", 
           RowBox[{"Rest", "[", "edgesMHz", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"phi", "=", 
         RowBox[{"RandomReal", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", 
             RowBox[{"2", " ", "Pi"}]}], "}"}], ",", "window"}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"a", "=", 
         RowBox[{"amp", " ", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"Log", "[", 
            RowBox[{
             RowBox[{"Rest", "[", "edgesMHz", "]"}], "/", 
             RowBox[{"Most", "[", "edgesMHz", "]"}]}], "]"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Total", "[", 
           RowBox[{"a", " ", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{"2", " ", "Pi", " ", "fMHz", " ", 
               RowBox[{"(", 
                RowBox[{"k", " ", "dtStepUs"}], ")"}]}], "+", "phi"}], 
             "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "0", ",", 
            RowBox[{"nPts", "-", "1"}]}], "}"}]}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"gateDts", "[", 
      RowBox[{"tg_", ",", "dtStepUs_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"n", "=", 
         RowBox[{"Max", "[", 
          RowBox[{"1", ",", 
           RowBox[{"Ceiling", "[", 
            RowBox[{"tg", "/", "dtStepUs"}], "]"}]}], "]"}]}], "}"}], ",", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"ConstantArray", "[", 
          RowBox[{"dtStepUs", ",", 
           RowBox[{"n", "-", "1"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"tg", "-", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"n", "-", "1"}], ")"}], " ", "dtStepUs"}]}], "}"}]}], 
        "]"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"One", " ", "noisy", " ", 
     RowBox[{"sample", ":", 
      RowBox[{"J23", " ", "pulse"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
